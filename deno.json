{
    "name": "@chapeaux/cpx-store",
    "version": "0.7.3",
    "description": "Reactive state management with a plugin architecture, signal-inspired computed properties, and a headless core that runs anywhere JavaScript runs.",
    "exports": {
        ".": "./src/cpx-store.ts",
        "./cpx-store-core": "./src/cpx-store-core.ts",
        "./plugins/middleware": "./src/plugins/middleware.ts",
        "./plugins/history": "./src/plugins/history.ts",
        "./plugins/persistence": "./src/plugins/persistence.ts",
        "./plugins/collab": "./src/plugins/collab.ts",
        "./transports/broadcast-channel": "./src/transports/broadcast-channel.ts",
        "./transports/websocket": "./src/transports/websocket.ts"
    },
    "publish": {
        "include": [
            "src/",
            "LICENSE",
            "README.md",
            "deno.json"
        ]
    },
    "tasks": {
        "build": "deno run -A tasks/build.js",
        "build:watch": "deno task build --watch",
        "doc": "deno run -A tasks/docs.js",
        "format": "deno fmt",
        "serve": "deno run -A tasks/serve.js",
        "serve:https": "deno run -A tasks/serve.js https",
        "test:logic": "deno test --allow-read src/stores/",
        "test:browser": "npx @web/test-runner --config web-test-runner.config.mjs",
        "test:watch": "npx @web/test-runner --config web-test-runner.config.mjs --watch"
    },
    "imports": {
        "@std/assert": "jsr:@std/assert@^1.0.19",
        "linkedom": "npm:linkedom",
        "@web/test-runner": "npm:@web/test-runner",
        "@web/test-runner-playwright": "npm:@web/test-runner-playwright",
        "@esm-bundle/chai": "npm:@esm-bundle/chai"
    },
    "compilerOptions": {
        "lib": ["deno.window", "dom"],
        "types": ["npm:@types/mocha"]
    },
    "nodeModulesDir": "auto"
}
